# Copy to .env and fill in values. Required in production: JWT_SECRET, DB_SSLMODE, CORS_ORIGINS.

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=erp
# Use "require" or "verify-full" in production; "disable" for local dev only.
DB_SSLMODE=disable

# Auth (required: no default in production)
JWT_SECRET=your-secret-at-least-32-chars

# CORS: comma-separated allowed origins (e.g. http://localhost:3000,https://app.example.com)
# Defaults to http://localhost:3000,http://localhost:5173 if unset.
CORS_ORIGINS=

# Optional: upload directory for project photos and avatars (default: ./uploads)
UPLOAD_DIR=./uploads

# Optional: server port (default: 8080)
PORT=8080

# Optional: use httpOnly cookie for JWT (set to true for production to reduce XSS token theft)
AUTH_USE_HTTPONLY_COOKIE=false
