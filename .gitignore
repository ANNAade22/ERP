# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# Environment variables (ALWAYS exclude this to keep your secrets safe!)
.env

# OS specific
.DS_Store

# Frontend dist / build / node_modules (assuming React/Vite/Node)
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.env*
frontend/.next/
